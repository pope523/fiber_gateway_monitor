{
  "_description": "Scale multiplier on JSON field - integer-tenths to float dBmV",
  "_json": {
    "downstream": {
      "channels": [
        {
          "channelId": 1,
          "power": 85,
          "lockStatus": true
        },
        {
          "channelId": 2,
          "power": 53,
          "lockStatus": true
        }
      ]
    }
  },
  "_resource": "/api/downstream",
  "_config": {
