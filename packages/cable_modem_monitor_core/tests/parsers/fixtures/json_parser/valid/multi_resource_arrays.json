{
  "_description": "Per-array resources — each array fetches from a different endpoint",
  "_resources": {
    "/api/qam": {"nodes": [{"id": 1, "freq": 735000000}]},
    "/api/ofdm": {"nodes": [{"id": 0, "pwr": -7.4}]}
  },
  "_config": {
    "format": "json",
    "arrays": [
      {
        "resource": "/api/qam",
        "array_path": "nodes",
        "fields": [
          {"key": "id", "field": "channel_id", "type": "integer"},
          {"key": "freq", "field": "frequency", "type": "integer"}
        ],
        "channel_type": {"fixed": "qam"}
      },
      {
        "resource": "/api/ofdm",
        "array_path": "nodes",
        "fields": [
          {"key": "id", "field": "channel_id", "type": "integer"},
          {"key": "pwr", "field": "power", "type": "float"}
        ],
        "channel_type": {"fixed": "ofdm"}
      }
    ]
  },
  "_expected": [
    {"channel_id": 1, "frequency": 735000000, "channel_type": "qam"},
    {"channel_id": 0, "power": -7.4, "channel_type": "ofdm"}
  ]
}
