    "fields": [
      {"key": "id", "field": "channel_id", "type": "integer"},
      {"key": "freq", "field": "channel_width", "type": "frequency", "separator": "~", "range": "span"}
    ]
  },
  "_expected": [
    {"channel_id": 1}
