      {
        "request": {
          "method": "GET",
          "url": "http://192.168.1.254/cgi-bin/login.ha",
          "headers": []
        },
        "response": {
          "status": 200,
          "headers": [
            {
              "name": "Content-Type",
              "value": "text/html; charset=windows-1252"
            }
          ],
          "content": {
            "mimeType": "text/html",
            "text": "<!DOCTYPE html PUBLIC \"-//W3C//DTD XHTML 1.0 Transitional//EN\" \"http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd\">\n<html lang=\"en\" xml:lang=\"en\" xmlns=\"http://www.w3.org/1999/xhtml\">\n<head><title>Login</title></head>\n<body>\n<div id=\"content-sub\">\n<h1>Device Access</h1>\n<p>Enter your Device Access Code to continue.</p>\n<form method=\"post\" action=\"/cgi-bin/login.ha\" name=\"loginform\">\n<input type=\"hidden\" name=\"nonce\" value=\"REDACTED_LOGIN_NONCE\" />\n<input type=\"password\" name=\"password\" id=\"password\" maxlength=\"12\" />\n<input type=\"hidden\" name=\"hashpassword\" value=\"\" />\n<input type=\"submit\" name=\"Continue\" value=\"Continue\" class=\"cssbtn\" />\n</form>\n</div>\n</body>\n</html>\n"
          }
        }
      },
      {
        "request": {
          "method": "POST",
